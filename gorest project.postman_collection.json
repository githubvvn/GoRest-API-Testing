      "name": "Post/ create new user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var response = JSON.parse(responseBody);\r",
              "tests[\"tc1 : ID Should Present\"] = responseBody.has(\"id\");\r",
              "tests[\"TC3 : Name should exist\"] = response.name != null;\r",
              "tests[\"TC4 : Email should exist\"] = response.email != null;\r",
              "tests[\"TC5 : Gender should be male\"] = response.gender == \"female\";\r",
              "tests[\"TC6 : Status should be active\"] = response.status == \"inactive\"\r",
              "const id = response.id;\r",
              "pm.collectionVariables.set(\"UID\", id)\r",
              "const username = response.name;\r",
              "pm.collectionVariables.set(\"UNAME\", username);\r",
              "console.log(id);\r",
              "console.log(username);"
            ],
